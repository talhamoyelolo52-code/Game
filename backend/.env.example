# ===== AI Provider =====
# Choose: openai | gemini | openrouter
AI_PROVIDER=openrouter

# ===== OpenAI (direct) =====
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ===== Gemini (direct) =====
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# ===== OpenRouter (recommended — access ALL models with one key) =====
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Free models available! Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   google/gemini-2.0-flash-exp:free
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen-2.5-coder-32b-instruct:free
#   deepseek/deepseek-chat:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# Optional: for OpenRouter rankings/attribution
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Kodari Clone

# ===== Server =====
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Discord OAuth =====
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ===== Dev Mode =====
DEV_LOGIN=true